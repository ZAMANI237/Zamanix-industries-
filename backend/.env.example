# ========== CLAUDE API ==========
CLAUDE_API_KEY=sk-ant-your-key-here

# ========== TWILIO SMS ==========
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# ========== CALENDLY ==========
CALENDLY_TOKEN=your_calendly_personal_access_token
CALENDLY_API_URL=https://api.calendly.com

# ========== STRIPE ==========
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ========== DATABASE ==========
DATABASE_URL=postgresql://user:password@localhost:5432/revenue_recovery
DB_HOST=localhost
DB_PORT=5432
DB_NAME=revenue_recovery
DB_USER=postgres
DB_PASSWORD=your_password

# ========== REDIS (Job Queue) ==========
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# ========== JWT ==========
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# ========== APP CONFIG ==========
NODE_ENV=development
PORT=3000
HOST=localhost

# ========== LOGGING ==========
LOG_LEVEL=debug

# ========== FRONTEND URL (for CORS) ==========
FRONTEND_URL=http://localhost:3000
LOVABLE_URL=https://your-lovable-project.lovable.app

# ========== WEBHOOK VERIFICATION ==========
ENABLE_WEBHOOK_VALIDATION=true
